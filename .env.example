# Anthropic API key for AI-generated recommendations (Phase 3)
# Get yours at https://console.anthropic.com/
ANTHROPIC_API_KEY=your-key-here

# Supabase credentials for auth + persistence (Phase 4)
# Get from: Supabase Dashboard → Integrations → Data API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=sb_publishable_your-key-here

# Audit mode: "lead_magnet" (default) or "advisory"
# AUDIT_MODE=lead_magnet

# Stripe (Phase 7), for paid tiers
# Get from: Stripe Dashboard → Developers → API Keys
# STRIPE_SECRET_KEY=sk_test_your-key-here
# STRIPE_WEBHOOK_SECRET=whsec_your-secret-here

# Stripe Price IDs, create products in Stripe Dashboard → Products
# STRIPE_PRICE_PRO=price_xxx
# STRIPE_PRICE_TEAM=price_yyy

# App URL (used for Stripe checkout redirect)
# APP_URL=https://structural-audit.streamlit.app
